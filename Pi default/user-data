#cloud-config
manage_resolv_conf: false
hostname: skyfood
manage_etc_hosts: true
packages:
- avahi-daemon
apt:
  preserve_sources_list: true
  conf: |
    Acquire {
      Check-Date "false";
    };
timezone: America/Sao_Paulo
keyboard:
  model: pc105
  layout: "br"
users:
- name: pi
  groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
  shell: /bin/bash
  lock_passwd: false
  passwd: "$y$jB5$j3ZKoFKGq.pJ53oEnRnA8/$EsvahR/U7WX6EJHlPTuNPy8Emnoc1oslERCLgtR1u51"
enable_ssh: true
ssh_pwauth: true
rpi:
  interfaces:
    serial: true
runcmd:
  - [ sh, -c, "install -o pi -m 700 -d /home/pi/.config/com.raspberrypi.connect" ]
  - [ sh, -c, "printf '%s\n' 'rpuak_CKzqSxqrV6S5SzMtuq3zifhi' > /home/pi/.config/com.raspberrypi.connect/auth.key && chown pi:pi /home/pi/.config/com.raspberrypi.connect/auth.key && chmod 600 /home/pi/.config/com.raspberrypi.connect/auth.key" ]
  - [ sh, -c, "install -o pi -m 700 -d /home/pi/.config/systemd/user/default.target.wants /home/pi/.config/systemd/user/paths.target.wants" ]
  - [ sh, -c, "UNIT_SRC=/usr/lib/systemd/user/rpi-connect.service; [ -f $UNIT_SRC ] || UNIT_SRC=/lib/systemd/user/rpi-connect.service; ln -sf $UNIT_SRC /home/pi/.config/systemd/user/default.target.wants/rpi-connect.service" ]
  - [ sh, -c, "UNIT_SRC=/usr/lib/systemd/user/rpi-connect-signin.path; [ -f $UNIT_SRC ] || UNIT_SRC=/lib/systemd/user/rpi-connect-signin.path; ln -sf $UNIT_SRC /home/pi/.config/systemd/user/paths.target.wants/rpi-connect-signin.path" ]
  - [ sh, -c, "UNIT_SRC=/usr/lib/systemd/user/rpi-connect-wayvnc.service; [ -f $UNIT_SRC ] || UNIT_SRC=/lib/systemd/user/rpi-connect-wayvnc.service; ln -sf $UNIT_SRC /home/pi/.config/systemd/user/default.target.wants/rpi-connect-wayvnc.service" ]
  - [ sh, -c, "chown -R pi:pi /home/pi/.config/systemd" ]
  - [ sh, -c, "install -d -m 0755 /var/lib/systemd/linger" ]
  - [ sh, -c, "install -m 0644 /dev/null /var/lib/systemd/linger/pi" ]
  - [ sh, -c, "loginctl enable-linger pi 2>/dev/null || true" ]
  - [ sleep, "2" ]
  - [ sh, -c, "systemctl --quiet --user --machine=pi@.host daemon-reload || true" ]
  - [ sh, -c, "systemctl --quiet --user --machine=pi@.host start rpi-connect.service || true" ]
  - [ sh, -c, "systemctl --quiet --user --machine=pi@.host start rpi-connect-signin.path || true" ]
  - [ sh, -c, "systemctl --quiet --user --machine=pi@.host start rpi-connect-wayvnc.service || true" ]
